{
  // Language version of C3.
  "langrev": "1",
  // Warnings used for all targets.
  "warnings": [ "no-unused" ],
  // Directories where C3 library files may be found.
  "dependency-search-paths": [ "lib" ],
  // Libraries to use for all targets.
  "dependencies": [ ],
  // Authors, optionally with email.
  "authors": [ "Troy Bick <troy.bick00@gmail.com>" ],
  // Version using semantic versioning.
  "version": "0.1.1",
  // Sources compiled for all targets.
  "sources": [ ],
  // Test sources compiled for all targets.
  "test-sources": [ "test/**" ],
  // C sources if the project also compiles C sources
  // relative to the project file.
  // "c-sources": [ "csource/**" ],
  // Include directories for C sources relative to the project file.
  // "c-include-dirs": [ "csource/include" ],
  // Build location, relative to project file.
  "build-dir": "build",
  // Output location, relative to project file.
  "output": "build",
  // Architecture and OS target.
  // You can use 'c3c --list-targets' to list all valid targets.
  // "target": "windows-x64",
  // Targets.
  "targets": {
    "analyze_temps-debug": {
      // Executable or library.
      "type": "executable",
      "sources-override": [ "src/analyze_temps/**" ],
      // Additional libraries, sources
      // and overrides of global settings here.
    },
    "analyze_temps-release": {
      // Executable or library.
      "type": "executable",
      "sources-override": [ "src/analyze_temps/**" ],
      "opt": "O3",
      // Additional libraries, sources
      // and overrides of global settings here.
    },
    "generate_temps-release": {
      // Executable or library.
      "type": "executable",
      "sources-override": [ "src/generate_temps/**" ],
      "opt": "O3",
      // Additional libraries, sources
      // and overrides of global settings here.
    },
    "clean_room_temps": {
      // Executable or library.
      "type": "executable",
      "sources-override": [ "src/clean_room_temps/**" ],
      "opt": "O3",
      // Additional libraries, sources
      // and overrides of global settings here.
    },
  },
  // Global settings.
  // CPU name, used for optimizations in the LLVM backend.
  "cpu": "generic",
  // Optimization: "O0", "O1", "O2", "O3", "O4", "O5", "Os", "Oz".
  "opt": "O0",
  // See resources/examples/project_all_settings.json and 'c3c --list-project-properties' to see more properties.
}
