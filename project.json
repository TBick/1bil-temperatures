{
  "langrev": "1",
  "warnings": [ "no-unused" ],
  "dependency-search-paths": [ "lib" ],
  "dependencies": [ ],
  "authors": [ "Troy Bick <troy.bick00@gmail.com>" ],
  "version": "0.1.1",
  "sources": [ ],
  "test-sources": [ "test/**" ],
  "build-dir": "build",
  "output": "build",
  "targets": {
    "analyze_temps-debug": {
      "type": "executable",
      "sources-override": [ "src/analyze_temps/**" ],
    },
    "analyze_temps-release": {
      "type": "executable",
      "sources-override": [ "src/analyze_temps/**" ],
      "opt": "O3",
    },
    "generate_temps-release": {
      "type": "executable",
      "sources-override": [ "src/generate_temps/**" ],
      "opt": "O3",
    },
    "clean_room_temps": {
      "type": "executable",
      "sources-override": [ "src/clean_room_temps/**" ],
      "opt": "O3",
    },
  },
  "cpu": "generic",
  "opt": "O0",
}
